# xAI (Grok) API key — required.
# Create one at https://console.x.ai
XAI_API_KEY=xai-your-key-here

# Optional. Port the local server listens on. Defaults to 3000.
PORT=3000

# Optional. Override the default Voice Agent model. Leave unset to use
# grok-voice-think-fast-1.0 (the flagship realtime voice model).
# XAI_REALTIME_MODEL=grok-voice-think-fast-1.0

# Optional. Verbose logging of every WebSocket frame preview on the server.
# Automatically on in development.
# VOICE_DEBUG=1
